{
  "name": "lidarviz-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "NODE_ENV=development node index.js",
    "build:client": "npm --prefix ../client ci && npm --prefix ../client run build",
    "postinstall": "sh -c 'if [ -f ../client/package.json ]; then npm run build:client; else echo \"Skipping client build (../client not found)\"; fi'"
  },
  "dependencies": {
    "@databricks/sql": "^1.12.0",
    "axios": "^1.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  }
}
